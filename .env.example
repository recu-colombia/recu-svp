APP_ENV=development
APP_NAME=recu-svp-nuevo
APP_HOST=0.0.0.0
APP_PORT=8010
LOG_LEVEL=INFO

# Base de datos: misma convención que recu-judicial (DB_* o DATABASE_*).
# TCP local o IP/puerto:
DB_HOST=localhost
# Cloud Run + Cloud SQL (sin VPC a IP privada): descomenta y enlaza la instancia en el servicio.
# DB_HOST=/cloudsql/PROJECT_ID:southamerica-east1:judicial-db
DB_PORT=5432
DB_NAME=recu_judicial
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=svp

# URL completa opcional (si tiene @, sustituye el armado por componentes):
# DATABASE_URL=postgresql://user:pass@host:5432/recu_judicial

OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_MODEL_CHEAP=gpt-4.1-mini
AI_MODEL_STRONG=gpt-4.1
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.1
AI_TIMEOUT=60
AI_MAX_RETRIES=2
SELECTION_CONFIDENCE_THRESHOLD=0.75

AUTO_SECTION_STRATEGY=resuelve_only
MAX_CANDIDATES=5

# Si false, no copia texto del span a complemento_indirecto aunque el catálogo permita CI abierto
SVP_CI_TEXTO_ABIERTO_DESDE_SPAN=true

# true = imprime en consola bloques con JSON indentado (>> solicitud / << respuesta)
IA_CONSOLE_PRETTY=true
