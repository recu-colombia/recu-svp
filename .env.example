APP_ENV=development
APP_NAME=recu-svp-nuevo
APP_HOST=0.0.0.0
APP_PORT=8010
LOG_LEVEL=INFO

DB_HOST=localhost
DB_PORT=5432
DB_NAME=recu_judicial
DB_USER=postgres
DB_PASSWORD=postgres
DB_SCHEMA=svp

OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_MODEL_CHEAP=gpt-4.1-mini
AI_MODEL_STRONG=gpt-4.1
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.1
AI_TIMEOUT=60
AI_MAX_RETRIES=2
SELECTION_CONFIDENCE_THRESHOLD=0.75

AUTO_SECTION_STRATEGY=resuelve_only
MAX_CANDIDATES=5

# true = imprime en consola bloques con JSON indentado (>> solicitud / << respuesta)
IA_CONSOLE_PRETTY=true
